PORT=3000
NODE_ENV=development

# Database (Supabase Postgres)
# Copy from Supabase Project Settings -> Database -> Connection string (URI)
# Format example:
# postgres://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional Supabase project values (for future API/storage usage)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Africa's Talking
AT_USERNAME=sandbox
AT_API_KEY=your_api_key
AT_PRODUCT_NAME=FreelanceEscrow
AT_SMS_SENDER_ID=

# Callbacks (public HTTPS URLs)
PAYMENT_CALLBACK_URL=https://your-domain.com/webhooks/payments
SMS_DELIVERY_CALLBACK_URL=https://your-domain.com/webhooks/sms

# Escrow behavior
PLATFORM_CURRENCY=KES
ESCROW_FEE_PERCENT=5
